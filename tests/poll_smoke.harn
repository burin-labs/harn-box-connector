import { init, poll_tick, shutdown } from "../src/lib"
import { expect, expect_eq } from "./assertions"

fn poll_ctx(cursor = nil, state = nil, extra = nil) {
  return {
    provider_id: "box",
    binding_id: "box.events",
    tick_at: "2026-07-06T12:00:00Z",
    cursor: cursor,
    state: state,
    max_batch_size: 10,
    binding: {
      id: "box.events",
      kind: "poll",
      config: {poll: {stream_type: "changes", limit: 100}, access_token: "secret_access"},
    },
  }
    + (extra ?? {})
}

fn events_body(entries, next_position) {
  return json_stringify(
    {entries: entries, next_stream_position: next_position, chunk_size: len(entries)},
  )
}

fn file_event(event_id, event_type, file_id, name) {
  return {
    type: "event",
    event_id: event_id,
    event_type: event_type,
    created_at: "2026-07-06T11:00:00-07:00",
    source: {type: "file", id: file_id, name: name, sha1: "sha-" + file_id},
  }
}

pipeline default() {
  egress_policy({allow: ["api.box.com"], default: "deny"})
  shutdown()
  init({access_token: "secret_access"})
  http_mock_clear()
  const api = "https://api.box.com/2.0"
  http_mock(
    "GET",
    "https://api.box.com/*",
    {
      responses: [
        {
          status: 200,
          body: events_body(
            [file_event("evt_1", "FILE.UPLOADED", "file_1", "Report 1.docx")],
            "pos_1",
          ),
          headers: {"content-type": "application/json"},
        },
        {
          status: 200,
          body: events_body(
            [file_event("evt_2", "FILE.DELETED", "file_2", "Report 2.pdf")],
            "pos_2",
          ),
          headers: {"content-type": "application/json"},
        },
        {
          status: 503,
          body: "{\"type\":\"error\",\"code\":\"unavailable\",\"message\":\"try later\"}",
          headers: {"content-type": "application/json"},
        },
        {
          status: 200,
          body: events_body(
            [file_event("evt_3", "FILE.TRASHED", "file_3", "Report 3.docx")],
            "pos_3",
          ),
          headers: {"content-type": "application/json"},
        },
      ],
    },
  )
  const first = poll_tick(poll_ctx())
  expect_eq(len(first.events), 1, "first tick emits one normalized event")
  expect_eq(first.events[0].kind, "box.events.file.uploaded", "poll event kind")
  expect_eq(first.events[0].payload.file_id, "file_1", "poll file id")
  expect_eq(first.events[0].payload.removed, false, "uploaded payload")
  expect_eq(first.cursor.stream_position, "pos_1", "first tick advances stream position")
  expect(
    first.state.poll_cache.get("box.events:evt_1:file_1") != nil,
    "first tick persists snapshot",
  )
  const second = poll_tick(poll_ctx(first.cursor, first.state))
  expect_eq(len(second.events), 1, "second tick emits one changed item")
  expect_eq(second.events[0].payload.file_id, "file_2", "second file id")
  expect_eq(second.events[0].payload.removed, true, "deleted event is removed")
  expect_eq(second.cursor.stream_position, "pos_2", "second tick stores cursor")
  const failed = poll_tick(poll_ctx(second.cursor, second.state))
  expect(is_err(failed), "retryable Box failures return Err without advancing local state")
  expect_eq(unwrap_err(failed).code, "unavailable", "retry error preserves Box code")
  const retried = poll_tick(poll_ctx(second.cursor, second.state))
  expect_eq(len(retried.events), 1, "retry with same cursor can emit after transient failure")
  expect_eq(retried.events[0].kind, "box.events.file.trashed", "trashed kind")
  expect_eq(retried.events[0].payload.removed, true, "trashed payload")
  const calls = http_mock_calls({include_sensitive: true})
  expect_eq(len(calls), 4, "one Box request per tick")
  expect(calls[0].url.starts_with(api + "/events?"), "first events URL prefix")
  expect(calls[0].url.contains("stream_type=changes"), "first events stream type query")
  expect(calls[0].url.contains("limit=100"), "first events limit query")
  expect(calls[0].url.contains("stream_position=now"), "first events position query")
  expect(calls[1].url.starts_with(api + "/events?"), "second events URL prefix")
  expect(calls[1].url.contains("stream_position=pos_1"), "second events position query")
  expect(calls[3].url.starts_with(api + "/events?"), "retry URL prefix")
  expect(calls[3].url.contains("stream_position=pos_2"), "retry position query")
  http_mock_clear()
  http_mock(
    "GET",
    api + "/events?stream_type=changes&limit=100&stream_position=now",
    {
      status: 200,
      body: events_body([file_event("evt_1", "FILE.UPLOADED", "file_1", "Report 1.docx")], "pos_4"),
      headers: {"content-type": "application/json"},
    },
  )
  const duplicate = poll_tick(poll_ctx(nil, first.state))
  expect_eq(len(duplicate.events), 0, "persisted state dedupes identical event")
  shutdown()
}
